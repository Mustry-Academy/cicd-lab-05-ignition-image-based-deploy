# Copy this file to .env (which is gitignored) before running `docker compose up`.
# Override the defaults for local development.
#
# This lab runs THREE Ignition gateways:
#   local  — your authoring gateway (bind-mounted; you develop here, file-based)
#   dev    — runs the IMAGE built by deploy.yml (push to main)
#   prod   — runs the IMAGE promoted by release.yml (tag push v*)
#
# Unlike Lab 04, dev/prod are NOT scanned over the API — they're redeployed by
# pulling a new image and recreating the container. So you only need an API key
# for the LOCAL gateway (used by the file-based inner loop / trigger-scan.sh).

# ---- Local gateway (http://localhost:8088) ------------------------------
# API key generated in the local gateway UI:
#   Config → Security → API Keys → New (role with Project Scan + Config Scan).
GATEWAY_ADMIN_USERNAME_LOCAL=admin
GATEWAY_ADMIN_PASSWORD_LOCAL=lab05password
IGNITION_API_KEY_LOCAL=replace-me-after-first-login

# ---- Dev gateway (http://localhost:8089) — deploy.yml target ------------
# No API key needed: deploy is an image pull + container recreate, not a scan.
GATEWAY_ADMIN_USERNAME_DEV=admin
GATEWAY_ADMIN_PASSWORD_DEV=lab05password

# ---- Prod gateway (http://localhost:8090) — release.yml target ----------
GATEWAY_ADMIN_USERNAME_PROD=admin
GATEWAY_ADMIN_PASSWORD_PROD=lab05password

# ---- Image registry (GHCR) ----------------------------------------------
# The repo that build/push/promote target. CI authenticates to ghcr.io with the
# workflow's built-in GITHUB_TOKEN — no registry password goes in .env.
#
# Set this to your fork's lowercase owner/repo. It's the base for image tags:
#   ghcr.io/<owner>/cicd-lab-05-ignition:sha-<short>
#   ghcr.io/<owner>/cicd-lab-05-ignition:dev | :prod | :vX.Y.Z
# Used by scripts/build-image.sh and scripts/deploy-image.sh for the local
# (non-CI) mirror of the build/deploy flow.
IGNITION_IMAGE_REPO=ghcr.io/<your-github-user>/cicd-lab-05-ignition

# ---- Image overrides consumed by docker-compose.yaml --------------------
# Which image the dev/prod gateways run. Leave UNSET and they fall back to the
# base Ignition image (an empty gateway) until the first deploy. The deploy
# scripts/workflows set these to a concrete tag and recreate the container.
# IGNITION_DEV_IMAGE=ghcr.io/<your-github-user>/cicd-lab-05-ignition:dev
# IGNITION_PROD_IMAGE=ghcr.io/<your-github-user>/cicd-lab-05-ignition:prod

# ---- Shared TimescaleDB sidecar ------------------------------------------
# One Postgres instance, three databases (ignition_loc, ignition_dev,
# ignition_prd). These creds are the superuser; create per-env users via
# the gateway DB connection UI if you want isolation.
POSTGRES_USER=ignition
POSTGRES_PASSWORD=ignition

# ---- GitHub Actions self-hosted runner ----------------------------------
# Auto-starts as part of `docker compose up -d`. The runner uses RUNNER_GITHUB_PAT
# (a PAT with `repo` scope) to fetch its own registration token, so you don't
# have to generate a registration token manually. Both vars MUST be set for
# the runner container to register; otherwise it'll restart-loop with an
# auth error in its logs.
#
# REPO_URL is your fork (not the upstream mustry-academy repo).
# RUNNER_GITHUB_PAT lives only in .env — never commit it.
RUNNER_REPO_URL=https://github.com/<your-github-user>/cicd-lab-05-ignition-image-based-deploy
RUNNER_GITHUB_PAT=ghp_replace-me-with-a-pat-that-has-repo-scope
RUNNER_NAME=lab05-runner
